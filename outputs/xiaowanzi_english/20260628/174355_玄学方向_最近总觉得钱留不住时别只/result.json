        "captions": "[{\"start\": 0, \"end\": 6576000, \"text\": \"玄学方向 最近总觉得钱留不住时，别只会说 help me\", \"font_size\": 10}, {\"start\": 6576000, \"end\": 17520000, \"text\": \"How can I help you?\\n有什么可以帮你？\", \"font_size\": 10}, {\"start\": 17520000, \"end\": 26064000, \"text\": \"Help me.\\n这句太空，对方不知道你到底要查、改、拿还是确认什么。\", \"font_size\": 10}, {\"start\": 26064000, \"end\": 31776000, \"text\": \"Could you help me with this?\\n可以帮我处理一下这个吗？\", \"font_size\": 10}, {\"start\": 31776000, \"end\": 37128000, \"text\": \"Could you check this for me?\\n可以帮我检查一下这个吗？\", \"font_size\": 10}, {\"start\": 37128000, \"end\": 46008000, \"text\": \"Could you help me figure out what I should do next?\\n可以帮我看看下一步该怎么处理吗？\", \"font_size\": 10}, {\"start\": 46008000, \"end\": 50160000, \"text\": \"Could you check this for me?\\n跟小丸子读一遍\", \"font_size\": 10}, {\"start\": 50160000, \"end\": 56304000, \"text\": \"你在玄学方向 最近总觉得钱留不住还卡过哪句？评论区告诉我。\", \"font_size\": 10}]",
