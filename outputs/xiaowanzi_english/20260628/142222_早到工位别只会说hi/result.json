        "captions": "[{\"start\": 0, \"end\": 2256000, \"text\": \"早到工位别只会说hi\", \"font_size\": 10}, {\"start\": 2256000, \"end\": 8544000, \"text\": \"这5句覆盖早到工位和同事聊当日安排的全场景实用表达\", \"font_size\": 10}, {\"start\": 8544000, \"end\": 15624000, \"text\": \"Morning, how's your day looking?\\n早，你今天安排多吗？\", \"font_size\": 10}, {\"start\": 15624000, \"end\": 22296000, \"text\": \"I have a few things to finish.\\n我有几件事要完成。\", \"font_size\": 10}, {\"start\": 22296000, \"end\": 29352000, \"text\": \"Let me check my calendar first.\\n我先看一下日历。\", \"font_size\": 10}, {\"start\": 29352000, \"end\": 36408000, \"text\": \"I have a meeting at ten.\\n我十点有个会。\", \"font_size\": 10}, {\"start\": 36408000, \"end\": 44040000, \"text\": \"I'll start with the urgent tasks.\\n我先处理紧急任务。\", \"font_size\": 10}, {\"start\": 44040000, \"end\": 49512000, \"text\": \"1. Morning, how's your day looking?\\n2. I have a few things to finish.\\n3. Let me check my calendar first.\\n4. I have a meeting at ten.\\n5. I'll start with the urgent tasks.\", \"font_size\": 10}, {\"start\": 49512000, \"end\": 52584000, \"text\": \"你今早到工位做的第一件事是什么？\", \"font_size\": 10}]",
