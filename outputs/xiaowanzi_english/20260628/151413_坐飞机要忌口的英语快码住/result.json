        "captions": "[{\"start\": 0, \"end\": 3072000, \"text\": \"坐飞机要忌口的英语快码住\", \"font_size\": 10}, {\"start\": 3072000, \"end\": 8712000, \"text\": \"这5句覆盖报过敏、要素食、换餐等全忌口场景\", \"font_size\": 10}, {\"start\": 8712000, \"end\": 18552000, \"text\": \"I'm allergic to nuts, no nut meals please.\\n我对坚果过敏，请不要给我含坚果的餐\", \"font_size\": 10}, {\"start\": 18552000, \"end\": 26808000, \"text\": \"Can I have a vegetarian meal please?\\n请问我可以要一份素食餐吗？\", \"font_size\": 10}, {\"start\": 26808000, \"end\": 36432000, \"text\": \"I don't eat beef, can I get another option?\\n我不吃牛肉，能给我换另一种餐吗？\", \"font_size\": 10}, {\"start\": 36432000, \"end\": 45288000, \"text\": \"Do you have lactose-free meals available?\\n你们有没有不含乳糖的餐食呀？\", \"font_size\": 10}, {\"start\": 45288000, \"end\": 55200000, \"text\": \"Please don't add any sauce to my meal.\\n请不要给我的餐食加任何酱料\", \"font_size\": 10}, {\"start\": 55200000, \"end\": 61488000, \"text\": \"1. I'm allergic to nuts, no nut meals please.\\n2. Can I have a vegetarian meal please?\\n3. I don't eat beef, can I get another option?\\n4. Do you have lactose-free meals available?\\n5. Please don't add any sauce to my meal.\", \"font_size\": 10}, {\"start\": 61488000, \"end\": 64944000, \"text\": \"你坐飞机有过什么特殊的饮食忌口需求吗？\", \"font_size\": 10}]",
