        "captions": "[{\"start\": 0, \"end\": 3936000, \"text\": \"餐厅点餐时，别只会说 help me\", \"font_size\": 10}, {\"start\": 3936000, \"end\": 12600000, \"text\": \"How can I help you?\\n有什么可以帮你？\", \"font_size\": 10}, {\"start\": 12600000, \"end\": 21960000, \"text\": \"Help me.\\n这句太空，对方不知道你到底要查、改、拿还是确认什么。\", \"font_size\": 10}, {\"start\": 21960000, \"end\": 28704000, \"text\": \"Could you help me with this?\\n可以帮我处理一下这个吗？\", \"font_size\": 10}, {\"start\": 28704000, \"end\": 34464000, \"text\": \"Could you check this for me?\\n可以帮我检查一下这个吗？\", \"font_size\": 10}, {\"start\": 34464000, \"end\": 43752000, \"text\": \"Could you help me figure out what I should do next?\\n可以帮我看看下一步该怎么处理吗？\", \"font_size\": 10}, {\"start\": 43752000, \"end\": 47832000, \"text\": \"Could you check this for me?\\n跟小丸子读一遍\", \"font_size\": 10}, {\"start\": 47832000, \"end\": 52104000, \"text\": \"你在餐厅点餐还卡过哪句？评论区告诉我。\", \"font_size\": 10}]",
