{
  "painpoint_conversion": {
    "structure": ["痛点命中", "具体表现", "玄学解释", "现实解释", "产品桥接", "使用建议", "自然问句"],
    "required_slots": [
      "sharp_hook",
      "symptoms",
      "mystic_view",
      "real_life_view",
      "product_bridge",
      "usage_tip",
      "soft_boundary",
      "interaction"
    ],
    "hook_rules": [
      "开头必须命中一个具体生活表现。",
      "不能只说先别焦虑、慢慢看、适合收藏。",
      "前2秒必须出现反差、悬念或被说中的感觉。"
    ],
    "symptom_rules": [
      "至少列出2-3个真实表现。",
      "表现要来自生活动作，比如刚到账就花掉、钱包乱、玄关乱、冲动付款、月底焦虑。"
    ],
    "product_rules": [
      "产品不能突然出现。",
      "必须先解释这个物件为什么和痛点有关。",
      "不能承诺发财、改命、必转运。"
    ],
    "quality_gate": {
      "min_symptoms": 2,
      "weak_hook_phrases": ["先别急着焦虑", "适合先收藏", "慢慢看"],
      "forbidden_claims": ["保证发财", "必定转运", "改命", "治病"]
    },
    "interaction_rule": "只保留自然问句，不使用评论区打、扣1、留言关键词。"
  },
  "scene_product_seed": {
    "structure": ["场景问题", "摆放逻辑", "推荐小物", "摆放建议", "自然问句"],
    "interaction_rule": "只问用户状态或偏好。"
  },
  "product_list": {
    "structure": ["收藏钩子", "3-5个产品清单", "适用场景", "购买建议", "自然问句"]
  }
}
